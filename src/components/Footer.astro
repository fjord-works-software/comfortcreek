---
interface Props {
  practiceName: string;
  email: string;
}
const { practiceName, email } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="bg-footer-bg text-footer-fg py-5 px-8">
  <div class="max-w-[1100px] mx-auto flex flex-row items-center justify-between gap-6 flex-wrap">
    <p class="text-[0.875rem] opacity-70 whitespace-nowrap">&copy; {year} {practiceName}</p>
    {email && (
      <a href={`mailto:${email}`} class="text-[0.875rem] opacity-70 underline whitespace-nowrap hover:opacity-100">{email}</a>
    )}
  </div>
</footer>
