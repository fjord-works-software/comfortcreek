---
interface Props {
  practiceName: string;
}
const { practiceName } = Astro.props;

const base = import.meta.env.BASE_URL;
const nav = [
  { label: 'Home', href: base },
  { label: 'Services', href: `${base}services` },
  { label: 'Accepted Insurances', href: `${base}accepted-insurances` },
  { label: 'About Us', href: `${base}about-us` },
  { label: 'Contact', href: `${base}contact` },
];

const current = Astro.url.pathname;
---
<header class="site-header sticky top-0 z-[100] bg-white border-b border-black/[0.12] h-[64px]">
  <div class="nav-inner max-w-[1100px] mx-auto px-8 h-full flex items-center justify-between gap-8">
    <a href={base} class="nav-logo hover:no-underline" aria-label={practiceName}>
      <img src={`${base}images/logo.png`} alt={practiceName} class="h-[44px] w-auto" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <ul class="nav-links flex list-none gap-10 items-center" role="list">
      {nav.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="text-[0.95rem] tracking-[0.02em] transition-opacity duration-150 hover:opacity-60 hover:no-underline"
            aria-current={current === href || (href !== base && current.startsWith(href)) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
