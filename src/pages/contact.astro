---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import settings from '../data/settings.json';

const page = await getEntry('pages', 'contact');
const email = page.data.email ?? settings.email;
---
<Layout
  title={page.data.title}
  description={page.data.intro}
>
  <PageHeader title={page.data.title} intro={page.data.intro} />

  <section>
    <div class="contact-layout">
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <p>
          You can also reach us directly by email:
        </p>
        <p>
          <a href={`mailto:${email}`}>{email}</a>
        </p>
        {settings.phone && (
          <p>
            <a href={`tel:${settings.phone}`}>{settings.phone}</a>
          </p>
        )}
        {settings.address && (
          <p>{settings.address}</p>
        )}
      </div>

      <div>
        {settings.web3forms_key ? (
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="contact-form"
          >
            <input type="hidden" name="access_key" value={settings.web3forms_key} />
            <input type="hidden" name="subject" value={`New message from ${settings.practice_name} website`} />
            <input type="checkbox" name="botcheck" style="display:none" />

            <div class="field-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>

            <div class="field-group">
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="field-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" />
            </div>

            <div class="field-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" required></textarea>
            </div>

            <button type="submit" class="btn">Send Message</button>
          </form>
        ) : (
          <div class="form-warning">
            <p>Contact form is not yet configured. Please email us directly at <a href={`mailto:${email}`}>{email}</a>.</p>
            <p class="form-warning-hint">Site admin: add your Web3Forms access key in Site Settings via the CMS.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</Layout>
