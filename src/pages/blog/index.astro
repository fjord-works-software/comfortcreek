---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { formatDate } from '../../utils/formatDate';

const posts = (await getCollection('blog', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Blog" description="Articles and updates from Comfort Creek Counseling">
  <PageHeader title="Blog" />

  <section>
    {posts.length > 0 ? (
      <div class="blog-grid container">
        {posts.map(post => (
          <article class="blog-card">
            <span class="date">{formatDate(post.data.pubDate)}</span>
            <h2>{post.data.title}</h2>
            {post.data.description && <p>{post.data.description}</p>}
            <a href={`/blog/${post.id}`} class="read-more">Read more &rarr;</a>
          </article>
        ))}
      </div>
    ) : (
      <div class="container text-center" style="padding: 3rem 0;">
        <p style="opacity: 0.6;">No posts yet. Check back soon.</p>
      </div>
    )}
  </section>
</Layout>
