---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { formatDate } from '../../utils/formatDate';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog', p => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Blog" description="Articles and updates from Comfort Creek Counseling">
  <PageHeader title="Blog" />

  <section class="py-20 px-8">
    {posts.length > 0 ? (
      <div class="grid gap-8 max-w-[1100px] mx-auto">
        {posts.map(post => (
          <article class="p-8 bg-bg-alt flex flex-col gap-2">
            <span class="text-[0.85rem] opacity-55">{formatDate(post.data.pubDate)}</span>
            <h2 class="text-[1.2rem]">{post.data.title}</h2>
            {post.data.description && <p class="text-[0.95rem] opacity-80">{post.data.description}</p>}
            <a href={`${base}blog/${post.id}`} class="text-[0.875rem] font-bold underline mt-2">Read more &rarr;</a>
          </article>
        ))}
      </div>
    ) : (
      <div class="max-w-[1100px] mx-auto text-center py-12">
        <p class="opacity-60">No posts yet. Check back soon.</p>
      </div>
    )}
  </section>
</Layout>
