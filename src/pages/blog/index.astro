---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Blog" description="Articles and updates from Comfort Creek Counseling">
  <div class="page-header">
    <h1>Blog</h1>
  </div>

  <section>
    {posts.length > 0 ? (
      <div class="blog-grid container">
        {posts.map(post => (
          <article class="blog-card">
            <span class="date">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
            <h2>{post.data.title}</h2>
            {post.data.description && <p>{post.data.description}</p>}
            <a href={`/blog/${post.id}`} class="read-more">Read more &rarr;</a>
          </article>
        ))}
      </div>
    ) : (
      <div class="container text-center" style="padding: 3rem 0;">
        <p style="opacity: 0.6;">No posts yet. Check back soon.</p>
      </div>
    )}
  </section>
</Layout>
