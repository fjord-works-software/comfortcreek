---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import settings from '../data/settings.json';

const page = await getEntry('pages', 'home');
const { hero_heading, hero_subtext, cta_label, cta_url, intro_heading, intro_body } = page.data;
---
<Layout
  title={settings.practice_name}
  description={hero_subtext}
>
  <section class="bg-brand">
    <div class="flex items-center gap-16 px-16 py-5 max-w-[1100px] mx-auto max-sm:flex-col max-sm:items-center max-sm:text-center max-sm:px-8 max-sm:py-12 max-sm:gap-8">
      <img src="/images/logo.png" alt={settings.practice_name} class="w-[320px] shrink-0 h-auto max-sm:w-40" />
      <div class="flex flex-col items-start gap-5 text-white max-sm:items-center">
        <h1 class="text-[clamp(1.8rem,3.5vw,2.6rem)] leading-tight">{hero_heading}</h1>
        <p class="text-[1.1rem] opacity-85 max-w-[520px]">{hero_subtext}</p>
        {cta_label && cta_url && (
          <a href={cta_url} class="inline-block px-8 py-[0.8rem] bg-[#121212] text-white font-bold text-[0.95rem] tracking-[0.04em] uppercase transition-opacity duration-150 hover:opacity-80 hover:no-underline">{cta_label}</a>
        )}
      </div>
    </div>
  </section>

  {intro_heading && (
    <section class="py-20 px-8">
      <div class="max-w-[1100px] mx-auto text-center">
        <h2 class="text-[clamp(1.4rem,2.5vw,1.8rem)] mb-4">{intro_heading}</h2>
        <p class="max-w-[640px] mx-auto text-[1.05rem] opacity-80 mb-8">{intro_body}</p>
        <a href="/services" class="inline-block px-8 py-[0.8rem] bg-transparent text-[#121212] border-2 border-[#121212] font-bold text-[0.95rem] tracking-[0.04em] uppercase transition-opacity duration-150 hover:opacity-80 hover:no-underline">View Services</a>
      </div>
    </section>
  )}
</Layout>
